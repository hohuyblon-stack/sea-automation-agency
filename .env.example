# SEA Automation Agency — Environment Variables
# Copy to .env and fill in your real values.
# NEVER commit .env to version control.

# ---------------------------------------------------------------------------
# Sender info (you)
# ---------------------------------------------------------------------------
SENDER_NAME=
SENDER_EMAIL=
SENDER_ZALO=

# ---------------------------------------------------------------------------
# Google APIs
# ---------------------------------------------------------------------------
# Spreadsheet ID for the CRM (set automatically by crm/setup_crm.py)
SHEETS_CRM_ID=
# Your personal Google account email — the CRM will be shared with this address
PERSONAL_GOOGLE_EMAIL=

# ---------------------------------------------------------------------------
# Facebook Graph API (for facebook_group_leads.py)
# Get from: https://developers.facebook.com/tools/explorer
# ---------------------------------------------------------------------------
FACEBOOK_ACCESS_TOKEN=

# ---------------------------------------------------------------------------
# Shopee Open Platform (per-client — usually goes in client's config.json)
# ---------------------------------------------------------------------------
# SHOPEE_PARTNER_ID=
# SHOPEE_PARTNER_KEY=

# ---------------------------------------------------------------------------
# Optional: Zalo OA Webhook (default Zalo notification URL)
# Create at: https://oa.zalo.me/home
# ---------------------------------------------------------------------------
ZALO_DEFAULT_WEBHOOK=

# ---------------------------------------------------------------------------
# Optional: SMTP fallback (if not using Gmail API)
# ---------------------------------------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# ---------------------------------------------------------------------------
# Apify API (for shopee_category_leads.py)
# Get from: https://console.apify.com/account/integrations
# ---------------------------------------------------------------------------
APIFY_API_TOKEN=

# ---------------------------------------------------------------------------
# Hunter.io API (for hunter_enrichment.py)
# Get from: https://hunter.io/api_keys
# ---------------------------------------------------------------------------
HUNTER_API_KEY=

