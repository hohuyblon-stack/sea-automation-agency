    "low_stock_threshold": 10,
    "critical_stock_threshold": 3,
    "alert_on_zero": true
  },
  "reporting": {
    "daily_report_time": "09:00",
    "timezone": "Asia/Ho_Chi_Minh",
    "report_to_zalo": true,
    "report_to_email": false,
    "email_recipients": []
  },
  "storage": {
    "orders_db": "data/orders.db",
    "inventory_db": "data/inventory.db",
    "logs_dir": "logs/"
  }
}
